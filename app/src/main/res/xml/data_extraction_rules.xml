<?xml version="1.0" encoding="utf-8"?>
<!--
    Data extraction rules for API 31+. Mirrors backup_rules.xml — excludes the SQLCipher
    database and its EncryptedSharedPreferences key file from both cloud backup and
    device-to-device transfer because the Android Keystore key does not transfer.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="file" path="wulfpak.db" />
        <exclude domain="file" path="wulfpak.db-shm" />
        <exclude domain="file" path="wulfpak.db-wal" />
        <exclude domain="sharedpref" path="wulfpak_db_prefs.xml" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="file" path="wulfpak.db" />
        <exclude domain="file" path="wulfpak.db-shm" />
        <exclude domain="file" path="wulfpak.db-wal" />
        <exclude domain="sharedpref" path="wulfpak_db_prefs.xml" />
    </device-transfer>
</data-extraction-rules>
