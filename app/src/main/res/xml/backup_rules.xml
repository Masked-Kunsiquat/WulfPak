<?xml version="1.0" encoding="utf-8"?>
<!--
    Backup rules for API 30 and below. Excludes the encrypted database and its key store
    because the Android Keystore master key is hardware-bound and cannot transfer to another
    device, making the backup unreadable on restore anyway.
-->
<full-backup-content>
    <exclude domain="file" path="wulfpak.db" />
    <exclude domain="file" path="wulfpak.db-shm" />
    <exclude domain="file" path="wulfpak.db-wal" />
    <exclude domain="sharedpref" path="wulfpak_db_prefs.xml" />
</full-backup-content>
